# =============================================================================
# AutoApply AI — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
POSTGRES_DB=autoapply
POSTGRES_USER=autoapply
POSTGRES_PASSWORD=change-me-generate-a-strong-password
DATABASE_URL=postgresql+asyncpg://autoapply:change-me-generate-a-strong-password@postgres:5432/autoapply
REDIS_URL=redis://redis:6379/0

# --- LLM Providers (set at least one) ---
LLM__PORTKEY_API_KEY=
LLM__OPENAI_API_KEY=
# OpenAI-compatible custom base URL; use this for 9router.
# Example: https://<your-9router-host>/v1
LLM__OPENAI_API_BASE=
LLM__GROQ_API_KEY=
LLM__GROQ_API_BASE=
LLM__GEMINI_API_KEY=
LLM__GEMINI_API_BASE=
LLM__OPENROUTER_API_KEY=
LLM__OPENROUTER_API_BASE=
LLM__GITHUB_TOKEN=

# LLM preferences
LLM__PREFERRED_PROVIDER=openai
# For 9router, use an OpenAI-compatible model name supported by your base URL.
# Example: openai/gpt-4o-mini or the model slug provided by 9router.
LLM__DEFAULT_MODEL=change-me-9router-model
# JSON array of fallback provider order; keep empty when routing only through 9router.
LLM__FALLBACK_PROVIDERS=[]
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=4096

# --- Browser Automation ---
BROWSER__HEADLESS=true
BROWSER__MAX_PARALLEL=2
# To reuse your existing Chrome sessions (LinkedIn, Indeed, etc.):
# Point this to your real Chrome profile directory:
# Windows: C:/Users/<you>/AppData/Local/Google/Chrome/User Data
# Mac: ~/Library/Application Support/Google/Chrome
# Or leave default for a standalone profile:
BROWSER__USER_DATA_DIR=./data/sessions/chrome_profile
BROWSER__KEEP_ALIVE=true
BROWSER__MAX_STEPS=50
BROWSER__MAX_FAILURES=3
BROWSER__STEP_TIMEOUT=120
BROWSER__USE_VISION=auto
BROWSER__LIVE_APPLY=false

# --- Job Discovery ---
# Exa AI semantic search for finding jobs across the web (optional)
EXA_API_KEY=

# --- Application Behavior ---
APPLY_MODE=review
# Options: autonomous, review, batch
MIN_ATS_SCORE=0.75
ENVIRONMENT=production
LOG_LEVEL=INFO
METRICS_TOKEN=change-me-generate-a-strong-token

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["https://autoapply.arsyadam.id"]

# --- Auth & Secrets ---
AUTH__SECRET_KEY=change-me-generate-a-strong-secret
SECRETS__APP_KEYS=change-me-generate-a-fernet-key
STORAGE__URL_SIGNING_SECRET=change-me-generate-a-strong-secret

# --- Platform Credentials (OPTIONAL if using Chrome profile session reuse) ---
# If BROWSER__USER_DATA_DIR points to your real Chrome profile AND you're
# already logged in to these platforms, you can leave these empty.
# The system will detect and reuse your existing sessions automatically.
#
# Only needed for first-time login or if sessions expire:
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

INDEED_EMAIL=
INDEED_PASSWORD=

GLASSDOOR_EMAIL=
GLASSDOOR_PASSWORD=
